rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: potholes
    // Document ID: auto-generated
    // Fields:
    //   - lat: number (required)
    //   - lng: number (required)
    //   - severity: string (required, 'low' | 'medium' | 'high')
    //   - description: string (optional, max 500 chars)
    //   - status: string (required, 'open' | 'fixed')
    //   - createdAt: timestamp (required)
    //   - reportedBy: string (required, uid)
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - role: string (required, 'user' | 'admin')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "parthanand67@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('reportedBy' in request.resource.data) || request.resource.data.reportedBy == request.auth.uid;
    }

    function uidNotModified() {
      return !('reportedBy' in request.resource.data) || request.resource.data.reportedBy == resource.data.reportedBy;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isValidPothole() {
      return hasRequiredFields(['lat', 'lng', 'severity', 'status', 'createdAt', 'reportedBy']) &&
             request.resource.data.lat is number &&
             request.resource.data.lng is number &&
             request.resource.data.severity in ['low', 'medium', 'high'] &&
             request.resource.data.status in ['open', 'fixed'] &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.reportedBy is string &&
             isValidOptionalString('description', 0, 500) &&
             isValidOptionalString('imageUrl', 0, 1048576); // 1MB max for base64 image
    }

    function isValidUser() {
      return hasRequiredFields(['role']) &&
             request.resource.data.role in ['user', 'admin'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /pothole_index/{docId} {
      // Allow public read access to the index to show total pothole counts on the landing page
      allow read: if true;
      // Allow any authenticated user to update the index (to add their pothole)
      // In a real production app, this should be done via Cloud Functions to prevent malicious overwrites,
      // but for this prototype, we allow authenticated users to update it.
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile, but cannot make themselves admin unless they are already admin
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser() && 
                    (request.resource.data.role == 'user' || isAdmin());
                    
      // Only admins can update roles
      allow update: if isAuthenticated() && isValidUser() && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
                    
      allow delete: if isAdmin();
    }

    match /potholes/{potholeId} {
      // Anyone authenticated can read potholes
      allow read: if isAuthenticated();
      
      // Anyone authenticated can report a pothole
      allow create: if isAuthenticated() && isValidPothole() && uidUnchanged() && request.resource.data.status == 'open';
      
      // Only admins can update or delete potholes
      allow update: if isAdmin() && isValidPothole() && uidNotModified();
      allow delete: if isAdmin();
    }
  }
}
